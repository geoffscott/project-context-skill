{
  "name": "project-context",
  "description": "Create and manage project workspaces organized by context, with channel-aware working directories",
  "version": "0.2.0",
  "author": "ananda",
  "commands": {
    "project-context": {
      "handler": "./project-context.sh",
      "description": "Create and manage projects (cd, pwd, create, list, info)"
    }
  },
  "triggers": [
    "start project",
    "new project",
    "create project",
    "project context",
    "/project-context"
  ],
  "permissions": {
    "filesystem": {
      "paths": [
        "~/.openclaw/project-context/**",
        "~/.openclaw/project-context/.state/**"
      ]
    },
    "git": {
      "required": true,
      "operations": [
        "init",
        "add",
        "commit",
        "log"
      ]
    }
  },
  "dependencies": [
    "git",
    "bash",
    "jq"
  ],
  "optional": []
}
